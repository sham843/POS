{
  "name": "pos",
  "version": "1.0.19",
  "description": "Hi-Tech Dairy Shop POS Application",
  "author": "Hi-Tech Dairy",
  "main": "main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "electron": "electron .",
    "dist": "powershell -Command \"$v=(Get-Content package.json|ConvertFrom-Json).version; $env:WINCODESIGN_PATH='C:\\Users\\shamj\\AppData\\Local\\electron-builder\\Cache\\winCodeSign\\winCodeSign-2.6.0'; ng build; electron-builder --win; Start-Sleep -Seconds 3; Compress-Archive -Path release/win-unpacked/* -DestinationPath \\\"release/Dairy Shop POS $v.zip\\\" -Force\"",
    "release": "powershell -Command \"$env:NODE_TLS_REJECT_UNAUTHORIZED='0'; $env:WINCODESIGN_PATH='C:\\Users\\shamj\\AppData\\Local\\electron-builder\\Cache\\winCodeSign\\winCodeSign-2.6.0'; ng build; electron-builder --win -p always\""
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "build": {
    "appId": "com.hitechdairy.pos",
    "productName": "Dairy Shop POS",
    "executableName": "Dairy Shop POS",
    "publish": [
      {
        "provider": "github",
        "owner": "sham843",
        "repo": "POS"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.14",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.0",
    "@ngx-translate/core": "^18.0.0",
    "@ngx-translate/http-loader": "^18.0.0",
    "apexcharts": "^5.16.0",
    "dexie": "^4.4.3",
    "electron-updater": "^6.3.9",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-angular": "^1.0.0",
    "material-design-icons": "^3.0.1",
    "ng-apexcharts": "^2.4.0",
    "ngx-spinner": "^21.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "xlsx-js-style": "^1.2.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "electron": "^41.7.1",
    "electron-builder": "^25.1.8",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}