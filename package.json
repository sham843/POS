{
  "name": "pos",
  "version": "1.0.0",
  "description": "Hi-Tech Dairy Shop POS Application",
  "author": "Hi-Tech Dairy",
  "main": "main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "electron": "electron .",
    "dist": "ng build && electron-builder --win"
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "build": {
    "appId": "com.hitechdairy.pos",
    "productName": "Dairy Shop POS",
    "executableName": "Dairy Shop POS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "^21.2.14",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.14",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.0",
    "@ngx-translate/core": "^18.0.0",
    "@ngx-translate/http-loader": "^18.0.0",
    "dexie": "^4.4.3",
    "lucide-angular": "^1.0.0",
    "material-design-icons": "^3.0.1",
    "ngx-spinner": "^21.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "electron": "^41.7.1",
    "electron-builder": "^25.1.8",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
